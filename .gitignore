# Docker ignores
docker/
docker-compose.yml
DOCKER.md
/.phpunit.cache
/node_modules
/public/hot
/public/storage
/storage/*.key
/storage/pail
/vendor
.env
.env.backup
.env.production
.phpactor.json
.phpunit.result.cache
Homestead.json
Homestead.yaml
npm-debug.log
yarn-error.log
/auth.json
/.fleet
/.idea
/.nova
/.vscode
/.zed

# Laravel recommended ignores
storage/app/public
storage/app/private
storage/framework
storage/logs
storage/debugbar
bootstrap/cache

# Ignore composer & npm logs
composer.lock
package-lock.json
yarn.lock

# Ignore database dumps/backups
database/*.sqlite
database/dumps

# Ignore user-specific files
*.sublime-workspace
*.sublime-project
*.swp
*.bak
*.tmp
